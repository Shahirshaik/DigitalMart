# ──────────────────────────────────────────────────────────────
# Digital Mart — Environment Variables
# Copy this file to .env.local and fill in your Supabase values
# ──────────────────────────────────────────────────────────────

# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — only used server-side (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Manual UPI payment collection (low-volume launch phase — see SETUP.md)
NEXT_PUBLIC_UPI_ID=your-upi-id@bank
NEXT_PUBLIC_UPI_PAYEE_NAME=Your Name
